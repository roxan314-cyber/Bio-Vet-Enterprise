# ========== TEST DE CREACIÓN ==========
def test_crear_historia_clinica_exitosa(session):
    # Preparación
    historia = HistoriaClinica(
        fecha=date.today(),
        id_cliente='CLI001',
        id_paciente='PAC001',
        id_doctor='DOC001',
        motivo_consulta='Fiebre y vómitos persistentes',
        condicion_corporal=3,
        diagnostico_dx='Gastroenteritis aguda',
        plan_accion='Suero intravenoso + dieta blanda por 3 días'
    )
    
    # Ejecución
    session.add(historia)
    session.commit()
    
    # Verificación
    recuperado = session.query(HistoriaClinica).first()
    assert recuperado is not None
    assert recuperado.id_consulta == 1  # AUTO_INCREMENT empieza en 1
    assert recuperado.fecha == date.today()
    assert recuperado.id_cliente == 'CLI001'
    assert recuperado.id_paciente == 'PAC001'
    recuperado.id_doctor == 'DOC001'
    assert recuperado.motivo_consulta == 'Fiebre y vómitos persistentes'
    assert recuperado.condicion_corporal == 3
    assert recuperado.diagnostico_dx == 'Gastroenteritis aguda'
    assert recuperado.plan_accion == 'Suero intravenoso + dieta blanda por 3 días'

