def test_obtener_historias_con_paginacion(session):
    # Crear 10 consultas
    for i in range(10):
        historia = HistoriaClinica(
            fecha=date.today(),
            id_cliente='CLI001',
            id_paciente='PAC001',
            id_doctor='DOC001'
        )
        session.add(historia)
    session.commit()
    
    # Paginación: página 1 (5 registros)
    pagina1 = session.query(HistoriaClinica).limit(5).offset(0).all()
    assert len(pagina1) == 5
    
    # Página 2 (siguientes 5)
    pagina2 = session.query(HistoriaClinica).limit(5).offset(5).all()
    assert len(pagina2) == 5
    assert pagina1[0].id_consulta != pagina2[0].id_consulta