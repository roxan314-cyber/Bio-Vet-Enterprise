import pytest
from sqlalchemy import create_engine, Column, String, Text, Integer, Date, ForeignKey
from sqlalchemy.ext.declarative import declarative_base
from sqlalchemy.orm import sessionmaker, relationship
from datetime import datetime, date
from sqlalchemy.exc import IntegrityError

# ========== CONFIGURACIÓN ==========
Base = declarative_base()

# Definir las 4 tablas para el test
class Cliente(Base):
    __tablename__ = 'Clientes'
    id_cliente = Column(String(10), primary_key=True)
    nombre_cliente = Column(String(100), nullable=False)
    cedula_identidad = Column(String(20), unique=True, nullable=False)
    telefono = Column(String(20))
    domicilio = Column(Text)
    
    historias = relationship("HistoriaClinica", back_populates="cliente")

class Paciente(Base):
    __tablename__ = 'Pacientes'
    id_paciente = Column(String(10), primary_key=True)
    nombre_paciente = Column(String(100), nullable=False)
    especie = Column(String(50))
    raza = Column(String(50))
    fecha_nacimiento = Column(Date)
    
    historias = relationship("HistoriaClinica", back_populates="paciente")

class Doctor(Base):
    __tablename__ = 'Doctores'
    id_doctor = Column(String(10), primary_key=True)
    nombre_doctor = Column(String(100), nullable=False)
    especialidad = Column(String(50), default='Medicina Veterinaria')
    numero_colegiado = Column(String(30))
    telefono = Column(String(20))
    correo = Column(String(100))
    turno = Column(String(20))
    estado = Column(String(15), default='Activo')
    
    historias = relationship("HistoriaClinica", back_populates="doctor")

class HistoriaClinica(Base):
    __tablename__ = 'Historias_Clinicas'
    
    id_consulta = Column(Integer, primary_key=True, autoincrement=True)
    fecha = Column(Date, nullable=False)
    id_cliente = Column(String(10), ForeignKey('Clientes.id_cliente'))
    id_paciente = Column(String(10), ForeignKey('Pacientes.id_paciente'))
    id_doctor = Column(String(10), ForeignKey('Doctores.id_doctor'))
    motivo_consulta = Column(Text)
    condicion_corporal = Column(Integer)
    diagnostico_dx = Column(Text)
    plan_accion = Column(Text)
    
    # Relaciones
    cliente = relationship("Cliente", back_populates="historias")
    paciente = relationship("Paciente", back_populates="historias")
    doctor = relationship("Doctor", back_populates="historias")

