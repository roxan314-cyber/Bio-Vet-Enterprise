    for h in historias:
        session.add(h)
    session.commit()
    
    # Filtrar por rango de fechas (Enero 2025)
    inicio = date(2025, 1, 1)
    fin = date(2025, 1, 31)
    resultado = session.query(HistoriaClinica).filter(
        HistoriaClinica.fecha.between(inicio, fin)
