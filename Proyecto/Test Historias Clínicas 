# ========== TEST DE AUTO_INCREMENT ==========
def test_auto_incremento_consecutivo(session):
    # Crear 3 consultas
    consultas = [
        HistoriaClinica(
            fecha=date(2025, 1, i),
            id_cliente='CLI001',
            id_paciente='PAC001',
            id_doctor='DOC001',
            motivo_consulta=f'Consulta {i}'
        ) for i in range(1, 4)
    ]
    
    for c in consultas:
        session.add(c)
    session.commit()
    
    # Verificar IDs consecutivos
    ids = [c.id_consulta for c in session.query(HistoriaClinica).order_by(HistoriaClinica.id_consulta).all()]
    assert ids == [1, 2, 3]

