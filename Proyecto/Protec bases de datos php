# scripts/check_credentials.py
import os
import sys

def check_production_credentials():
    """Verifica que no haya credenciales por defecto"""
    if os.getenv('NODE_ENV') != 'production':
        return True
    
    # Lista de passwords inseguros
    insecure = ['root', 'password', '123456', 'admin', 'test']
    db_password = os.getenv('DB_PASSWORD', '')
    
    if db_password in insecure:
        print("CRÍTICO: Contraseña insegura en producción!")
        print("   No uses contraseñas por defecto.")
        sys.exit(1)
    
    # Verificar que las variables existan
    required = ['DB_HOST', 'DB_NAME', 'DB_USER', 'DB_PASSWORD', 'JWT_SECRET']
    missing = [v for v in required if not os.getenv(v)]
    
    if missing:
        print(f"Faltan credenciales: {', '.join(missing)}")
        sys.exit(1)
    
    print("Credenciales válidas")
    return True

if __name__ == "__main__":
    check_production_credentials()

// scripts/healthcheck.js
const db = require('../config/database');

async function verifyConnection() {
    console.log('Verificando conexión a BD...');
    
    try {
        await db.authenticate();
        console.log('Conexión exitosa');
        
        // Verificar que la BD existe
        await db.query('SELECT 1');
        console.log('Base de datos accesible');
        
        // Verificar tablas críticas
        const tables = ['Clientes', 'Doctores', 'Pacientes', 'Historias_Clinicas'];
        for (const table of tables) {
            const result = await db.query(`SHOW TABLES LIKE '${table}'`);
            if (result[0].length === 0) {
                console.warn(`Tabla ${table} no encontrada`);
            }
        }
        
        console.log('Health check completado');
    } catch (error) {
        console.error('Error de conexión:', error.message);
        process.exit(1);
    }
}

verifyConnection();

