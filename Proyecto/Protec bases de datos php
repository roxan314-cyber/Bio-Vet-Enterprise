// utils/logSanitizer.js
class LogSanitizer {
    static sanitize(obj) {
        // Crear copia profunda
        const sanitized = JSON.parse(JSON.stringify(obj));
        
        // Campos a ocultar
        const sensitiveFields = [
            'password', 'pwd', 'pass', 'token', 
            'secret', 'api_key', 'authorization',
            'access_token', 'refresh_token'
        ];
        
        const sanitizeRecursive = (data) => {
            if (typeof data !== 'object' || data === null) return data;
            
            if (Array.isArray(data)) {
                return data.map(item => sanitizeRecursive(item));
            }
            
            Object.keys(data).forEach(key => {
                if (sensitiveFields.includes(key.toLowerCase())) {
                    data[key] = '***';
                } else if (typeof data[key] === 'object') {
                    sanitizeRecursive(data[key]);
                }
            });
            
            return data;
        };
        
        return sanitizeRecursive(sanitized);
    }
    
    static log(message, data) {
        const safeData = this.sanitize(data);
        console.log(message, JSON.stringify(safeData, null, 2));
    }
}

