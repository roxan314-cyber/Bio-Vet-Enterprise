# config/database.py
import os
import logging
from dotenv import load_dotenv
from pathlib import Path

# Cargar .env solo en desarrollo
env_file = Path('.env')
if env_file.exists() and os.getenv('NODE_ENV') != 'production':
    load_dotenv()
    logging.info("Cargando configuración desde .env")
else:
    logging.info("Usando variables de entorno del sistema")

class DatabaseConfig:
    """Configuración segura con validación"""
    
    @staticmethod
    def get_db_url():
        """Obtiene URL de conexión sin exponer credenciales en logs"""
        
        # Intentar desde variables de entorno
        host = os.getenv('DB_HOST')
        port = os.getenv('DB_PORT', '3306')
        database = os.getenv('DB_NAME')
        user = os.getenv('DB_USER')
        password = os.getenv('DB_PASSWORD')
        
        # Validar que existan credenciales
        if not all([host, database, user, password]):
            missing = []
            if not host: missing.append('DB_HOST')
            if not database: missing.append('DB_NAME')
            if not user: missing.append('DB_USER')
            if not password: missing.append('DB_PASSWORD')
            
            raise ValueError(
                f"Credenciales faltantes: {', '.join(missing)}. "
                "Revisa tu archivo .env o variables de entorno."
            )
        
        # Construir URL (NUNCA loguear esta URL completa)
        dialect = os.getenv('DB_DIALECT', 'mysql')
        url = f"{dialect}://{user}:{password}@{host}:{port}/{database}"
        
        # Log seguro (sin password)
        safe_url = f"{dialect}://{user}:***@{host}:{port}/{database}"
        logging.info(f"Conectando a: {safe_url}")
        
        return url
    
    @staticmethod
    def get_pool_config():
        """Configuración del pool de conexiones"""
        return {
            'pool_size': int(os.getenv('DB_POOL_SIZE', 10)),
            'max_overflow': int(os.getenv('DB_MAX_OVERFLOW', 20)),
            'pool_pre_ping': True,
            'pool_recycle': 3600,  # Reciclar conexiones cada hora
            'echo': os.getenv('SQL_ECHO', 'false').lower() == 'true'
        }

# Uso
DATABASE_URL = DatabaseConfig.get_db_url()

// config/database.js
const { Sequelize } = require('sequelize');
require('dotenv').config();

class DatabaseConnection {
    constructor() {
        this.validateCredentials();
        this.sequelize = null;
    }
    
    validateCredentials() {
        const required = ['DB_HOST', 'DB_NAME', 'DB_USER', 'DB_PASSWORD'];
        const missing = required.filter(key => !process.env[key]);
        
        if (missing.length > 0) {
            throw new Error(
                `Credenciales faltantes: ${missing.join(', ')}\n` +
                `Crea un archivo .env basado en .env.example`
            );
        }
        
        // Verificar que no esté en producción con credenciales por defecto
        if (process.env.NODE_ENV === 'production') {
            const defaultPasswords = ['root', 'password', '123456', 'admin'];
            if (defaultPasswords.includes(process.env.DB_PASSWORD)) {
                throw new Error(
                    'CRÍTICO: No uses contraseñas por defecto en producción'
                );
            }
        }
    }
    
    getConnection() {
        if (!this.sequelize) {
            // Log seguro (ocultar password)
            const safeConfig = {
                host: process.env.DB_HOST,
                database: process.env.DB_NAME,
                user: process.env.DB_USER,
                password: '****'
            };
            console.log('Conectando a BD:', safeConfig);
            
            this.sequelize = new Sequelize(
                process.env.DB_NAME,
                process.env.DB_USER,
                process.env.DB_PASSWORD,
                {
                    host: process.env.DB_HOST,
                    port: process.env.DB_PORT || 3306,
                    dialect: process.env.DB_DIALECT || 'mysql',
                    pool: {
                        max: parseInt(process.env.DB_POOL_MAX) || 10,
                        min: parseInt(process.env.DB_POOL_MIN) || 0,
                        acquire: 30000,
                        idle: 10000
                    },
                    logging: process.env.NODE_ENV === 'development' 
                        ? (msg) => console.log('SQL:', msg.replace(/password=[^&]*/g, 'password=***'))
                        : false
                }
            );
        }
        return this.sequelize;
    }
}

module.exports = new DatabaseConnection();

# config/aws_secrets.py
import boto3
import json
import os
from botocore.exceptions import ClientError

class SecretsManager:
    @staticmethod
    def get_secret(secret_name):
        """Obtener credenciales desde AWS Secrets Manager"""
        session = boto3.session.Session()
        client = session.client(
            service_name='secretsmanager',
            region_name=os.getenv('AWS_REGION', 'us-east-1')
        )
        
        try:
            response = client.get_secret_value(SecretId=secret_name)
            secret = json.loads(response['SecretString'])
            return secret
        except ClientError as e:
            print(f"Error obteniendo secret: {e}")
            raise

# Uso en producción
