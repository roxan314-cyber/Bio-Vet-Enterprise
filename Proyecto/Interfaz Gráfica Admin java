    private JPanel crearPanelReportes() {
        JPanel panel = new JPanel(new GridBagLayout());
        panel.setBorder(BorderFactory.createEmptyBorder(20, 20, 20, 20));
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.insets = new Insets(10, 10, 10, 10);
        gbc.fill = GridBagConstraints.HORIZONTAL;
        
        // Panel de métricas
        JPanel panelMetricas = new JPanel(new GridLayout(2, 3, 15, 15));
        panelMetricas.setBorder(BorderFactory.createTitledBorder("Métricas del Sistema"));
        
        JLabel lblTotalMySQL = new JLabel("Total MySQL: 0 registros");
        JLabel lblTotalPostgres = new JLabel("Total PostgreSQL: 0 registros");
        JLabel lblActividad = new JLabel("Actividad reciente: 0 operaciones");
        
        panelMetricas.add(lblTotalMySQL);
        panelMetricas.add(lblTotalPostgres);
        panelMetricas.add(lblActividad);
        
        // Panel de gráfico simplificado
        JPanel panelGrafico = new JPanel() {
            @Override
            protected void paintComponent(Graphics g) {
                super.paintComponent(g);
                Graphics2D g2d = (Graphics2D) g;
                g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                
                int totalMySQL = modelMySQL.getRowCount();
                int totalPostgres = modelPostgres.getRowCount();
                int total = Math.max(totalMySQL + totalPostgres, 1);
                
                int anchoMySQL = (int)(getWidth() * 0.4);
                int anchoPostgres = (int)(getWidth() * 0.4);
                
                g2d.setColor(new Color(100, 149, 237));
                g2d.fillRect(50, getHeight() - 100, anchoMySQL, 80);
                g2d.setColor(Color.BLACK);
                g2d.drawString("MySQL: " + totalMySQL, 50, getHeight() - 110);
                
                g2d.setColor(new Color(52, 73, 94));
                g2d.fillRect(50 + anchoMySQL + 50, getHeight() - 100, anchoPostgres, 80);
                g2d.setColor(Color.BLACK);
                g2d.drawString("PostgreSQL: " + totalPostgres, 50 + anchoMySQL + 50, getHeight() - 110);
            }
        };
        panelGrafico.setPreferredSize(new Dimension(400, 200));
        panelGrafico.setBorder(BorderFactory.createLineBorder(Color.GRAY));
        panelGrafico.setBackground(Color.WHITE);
        
        gbc.gridx = 0;
        gbc.gridy = 0;
        gbc.gridwidth = 2;
        panel.add(panelMetricas, gbc);
        
        gbc.gridy = 1;
        panel.add(panelGrafico, gbc);
        
        // Actualizar métricas
        actualizarMetricas(lblTotalMySQL, lblTotalPostgres);
        
        return panel;
    }
    
