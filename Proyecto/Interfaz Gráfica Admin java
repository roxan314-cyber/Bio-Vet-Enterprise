    private void agregarRegistroMySQL() {
        JTextField nombreField = new JTextField(20);
        JTextField emailField = new JTextField(20);
        
        JPanel panel = new JPanel(new GridLayout(2, 2, 5, 5));
        panel.add(new JLabel("Nombre:"));
        panel.add(nombreField);
        panel.add(new JLabel("Email:"));
        panel.add(emailField);
        
        int result = JOptionPane.showConfirmDialog(this, panel, "Agregar Usuario MySQL", 
                                                   JOptionPane.OK_CANCEL_OPTION);
        if (result == JOptionPane.OK_OPTION) {
            String query = "INSERT INTO usuarios (nombre, email, fecha_registro) VALUES (?, ?, NOW())";
            try (PreparedStatement pstmt = connMySQL.prepareStatement(query)) {
                pstmt.setString(1, nombreField.getText());
                pstmt.setString(2, emailField.getText());
                pstmt.executeUpdate();
                cargarDatosMySQL();
                JOptionPane.showMessageDialog(this, "Usuario agregado exitosamente");
            } catch (SQLException e) {
                JOptionPane.showMessageDialog(this, "Error: " + e.getMessage());
            }
        }
    }
    
