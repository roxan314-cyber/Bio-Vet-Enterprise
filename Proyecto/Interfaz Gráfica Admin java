    private void exportarReporte() {
        StringBuilder reporte = new StringBuilder();
        reporte.append("=== REPORTE GENERAL DEL SISTEMA ===\n\n");
        reporte.append("Fecha: ").append(new java.util.Date()).append("\n\n");
        
        reporte.append("BASE DE DATOS MySQL:\n");
        reporte.append("Total registros: ").append(modelMySQL.getRowCount()).append("\n");
        reporte.append("Lista de usuarios:\n");
        for (int i = 0; i < modelMySQL.getRowCount(); i++) {
            reporte.append("  - ").append(modelMySQL.getValueAt(i, 1))
                   .append(" (").append(modelMySQL.getValueAt(i, 2)).append(")\n");
        }
        
        reporte.append("\nBASE DE DATOS PostgreSQL:\n");
        reporte.append("Total registros: ").append(modelPostgres.getRowCount()).append("\n");
        reporte.append("Lista de usuarios:\n");
        for (int i = 0; i < modelPostgres.getRowCount(); i++) {
            reporte.append("  - ").append(modelPostgres.getValueAt(i, 1))
                   .append(" (").append(modelPostgres.getValueAt(i, 2)).append(")\n");
        }
        
        JTextArea textArea = new JTextArea(reporte.toString(), 20, 50);
        textArea.setEditable(false);
        JScrollPane scrollPane = new JScrollPane(textArea);
        
        JOptionPane.showMessageDialog(this, scrollPane, "Reporte General", JOptionPane.INFORMATION_MESSAGE);
    }
    
    private void limpiarRegistros() {
        int confirm = JOptionPane.showConfirmDialog(this, 
            "¿Está seguro de limpiar registros antiguos (más de 30 días) en ambas bases de datos?", 
            "Confirmar Limpieza", JOptionPane.YES_NO_OPTION, JOptionPane.WARNING_MESSAGE);
        
        if (confirm == JOptionPane.YES_OPTION) {
            String deleteQuery = "DELETE FROM usuarios WHERE fecha_registro < (CURRENT_DATE - INTERVAL '30 days')";
            try {
                // PostgreSQL
                try (Statement stmt = connPostgres.createStatement()) {
                    int pgDeleted = stmt.executeUpdate(deleteQuery);
                    JOptionPane.showMessageDialog(this, "PostgreSQL: " + pgDeleted + " registros eliminados");
                }
                
                // MySQL
                String mysqlQuery = "DELETE FROM usuarios WHERE fecha_registro < DATE_SUB(NOW(), INTERVAL 30 DAY)";
                try (Statement stmt = connMySQL.createStatement()) {
                    int mysqlDeleted = stmt.executeUpdate(mysqlQuery);
                    JOptionPane.showMessageDialog(this, "MySQL: " + mysqlDeleted + " registros eliminados");
                }
                
                cargarDatos();
            } catch (SQLException e) {
                JOptionPane.showMessageDialog(this, "Error limpiando registros: " + e.getMessage());
            }
        }
    }
    
