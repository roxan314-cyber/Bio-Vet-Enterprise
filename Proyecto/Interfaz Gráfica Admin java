    }
    
    private void cargarDatosMySQL() {
        String query = "SELECT id, nombre, email, fecha_registro FROM usuarios ORDER BY id";
        try (Statement stmt = connMySQL.createStatement();
             ResultSet rs = stmt.executeQuery(query)) {
            
            modelMySQL.setRowCount(0);
            modelMySQL.setColumnIdentifiers(new String[]{"ID", "Nombre", "Email", "Fecha Registro"});
            
            while (rs.next()) {
                Vector<Object> row = new Vector<>();
                row.add(rs.getInt("id"));
                row.add(rs.getString("nombre"));
                row.add(rs.getString("email"));
                row.add(rs.getDate("fecha_registro"));
                modelMySQL.addRow(row);
            }
            
            lblStatusMySQL.setText("MySQL: Conectado - " + modelMySQL.getRowCount() + " registros");
        } catch (SQLException e) {
            lblStatusMySQL.setText("MySQL: Error");
            JOptionPane.showMessageDialog(this, "Error cargando datos MySQL: " + e.getMessage());
        }
    }
    
    private void cargarDatosPostgres() {
