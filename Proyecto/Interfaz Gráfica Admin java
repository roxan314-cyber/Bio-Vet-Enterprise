    private void conectarBasesDatos() {
        try {
            // Conexión MySQL
            Class.forName("com.mysql.cj.jdbc.Driver");
            connMySQL = DriverManager.getConnection(MYSQL_URL, MYSQL_USER, MYSQL_PASS);
            
            // Conexión PostgreSQL
            Class.forName("org.postgresql.Driver");
            connPostgres = DriverManager.getConnection(POSTGRES_URL, POSTGRES_USER, POSTGRES_PASS);
            
        } catch (ClassNotFoundException | SQLException e) {
            JOptionPane.showMessageDialog(this, "Error de conexión: " + e.getMessage(), 
                                        "Error", JOptionPane.ERROR_MESSAGE);
        }
    }
    
