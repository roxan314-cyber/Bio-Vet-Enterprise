# ========== TEST DE CONSULTA ==========
def test_buscar_cliente_por_cedula(session):
    # Preparar datos
    cliente = Cliente(
        id_cliente='CLI004',
        nombre_cliente='Ana Martínez',
        cedula_identidad='44444444D',
        telefono='650000004'
    )
    session.add(cliente)
    session.commit()
    
    # Buscar por cédula
    resultado = session.query(Cliente).filter_by(cedula_identidad='44444444D').first()
    
    assert resultado is not None
    assert resultado.id_cliente == 'CLI004'
    assert resultado.nombre_cliente == 'Ana Martínez'

def test_buscar_cliente_inexistente(session):
    resultado = session.query(Cliente).filter_by(cedula_identidad='99999999Z').first()
    assert resultado is None

# ========== TEST DE ACTUALIZACIÓN ==========
def test_actualizar_domicilio(session):
    # Crear cliente
    cliente = Cliente(
        id_cliente='CLI005',
        nombre_cliente='Pedro Sánchez',
        cedula_identidad='55555555E',
        domicilio='Calle Vieja 1'
    )
    session.add(cliente)
    session.commit()
    
    # Actualizar domicilio
    cliente.domicilio = 'Calle Nueva 456, Barcelona'
    session.commit()
    
    # Verificar
    recuperado = session.query(Cliente).get('CLI005')
    assert recuperado.domicilio == 'Calle Nueva 456, Barcelona'

# ========== TEST DE ELIMINACIÓN ==========
def test_eliminar_cliente(session):
    # Crear cliente
    cliente = Cliente(
        id_cliente='CLI006',
        nombre_cliente='Laura Gómez',
        cedula_identidad='66666666F'
    )
    session.add(cliente)
    session.commit()
    
    # Eliminar
    session.delete(cliente)
    session.commit()
    
    # Verificar que no existe
    recuperado = session.query(Cliente).get('CLI006')
    assert recuperado is None

# ========== TEST DE MÚLTIPLES REGISTROS ==========
def test_listar_todos_clientes(session):
    # Insertar 3 clientes
    clientes = [
        Cliente(id_cliente='CLI007', nombre_cliente='A', cedula_identidad='111A'),
        Cliente(id_cliente='CLI008', nombre_cliente='B', cedula_identidad='222B'),
        Cliente(id_cliente='CLI009', nombre_cliente='C', cedula_identidad='333C')
    ]
    for c in clientes:
        session.add(c)
    session.commit()
    
    # Consultar todos
    todos = session.query(Cliente).all()
    assert len(todos) == 3
    assert {c.nombre_cliente for c in todos} == {'A', 'B', 'C'}