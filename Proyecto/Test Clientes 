import pytest
from sqlalchemy import create_engine, Column, String, Text
from sqlalchemy.ext.declarative import declarative_base
from sqlalchemy.orm import sessionmaker
from werkzeug.security import generate_password_hash  # Si usas login

# ========== CONFIGURACIÓN ==========
Base = declarative_base()

class Cliente(Base):
    __tablename__ = 'Clientes'
    
    id_cliente = Column(String(10), primary_key=True)
    nombre_cliente = Column(String(100), nullable=False)
    cedula_identidad = Column(String(20), unique=True, nullable=False)
    telefono = Column(String(20))
    domicilio = Column(Text)

# BD en memoria para tests
@pytest.fixture
def session():
    engine = create_engine('sqlite:///:memory:')
    Base.metadata.create_all(engine)
    Session = sessionmaker(bind=engine)
    return Session()

# ========== TEST DE CREACIÓN ==========
def test_crear_cliente_exitoso(session):
    # Preparación
    cliente = Cliente(
        id_cliente='CLI001',
        nombre_cliente='María González',
        cedula_identidad='12345678A',
        telefono='+34 912345678',
        domicilio='Calle Principal 123, Madrid'
    )
    
    # Ejecución
    session.add(cliente)
    session.commit()
    
    # Verificación
    recuperado = session.query(Cliente).filter_by(id_cliente='CLI001').first()
    assert recuperado is not None
    assert recuperado.nombre_cliente == 'María González'
    assert recuperado.cedula_identidad == '12345678A'
    assert recuperado.telefono == '+34 912345678'
    assert recuperado.domicilio == 'Calle Principal 123, Madrid'

# ========== TEST DE VALIDACIONES ==========
def test_cedula_unica(session):
    # Crear primer cliente
    cliente1 = Cliente(
        id_cliente='CLI001',
        nombre_cliente='Juan Pérez',
        cedula_identidad='11111111A',
        telefono='600000001'
    )
    session.add(cliente1)
    session.commit()
    
    # Intentar crear segundo con misma cédula
    cliente2 = Cliente(
        id_cliente='CLI002',
        nombre_cliente='Carlos López',
        cedula_identidad='11111111A',  # Misma cédula
        telefono='600000002'
    )
    
    # Verificar que lanza error UNIQUE constraint
    with pytest.raises(Exception) as excinfo:
        session.add(cliente2)
        session.commit()
    
    assert 'UNIQUE constraint' in str(excinfo.value)

def test_id_cliente_longitud(session):
    # Intentar crear con ID > 10 caracteres
