import pytest
from sqlalchemy import create_engine, Column, String, Integer
from sqlalchemy.ext.declarative import declarative_base
from sqlalchemy.orm import sessionmaker
from datetime import datetime
import re

# ========== CONFIGURACIÓN ==========
Base = declarative_base()

class Doctor(Base):
    __tablename__ = 'Doctores'
    
    id_doctor = Column(String(10), primary_key=True)
    nombre_doctor = Column(String(100), nullable=False)
    especialidad = Column(String(50), default='Medicina Veterinaria')
    numero_colegiado = Column(String(30))
    telefono = Column(String(20))
    correo = Column(String(100))
    turno = Column(String(20))
    estado = Column(String(15), default='Activo')
    
    def __repr__(self):
        return f"<Doctor {self.id_doctor}: {self.nombre_doctor}>"

# BD en memoria para tests
@pytest.fixture
def session():
    engine = create_engine('sqlite:///:memory:')
    Base.metadata.create_all(engine)
    Session = sessionmaker(bind=engine)
    return Session()

# ========== TEST DE CREACIÓN ==========
def test_crear_doctor_exitoso(session):
    # Preparación
    doctor = Doctor(
        id_doctor='DOC001',
        nombre_doctor='María Rodríguez',
        especialidad='Cirugía Veterinaria',
        numero_colegiado='COL-12345',
        telefono='+34 612345678',
        correo='maria.rodriguez@clinicavet.com',
        turno='Mañana',
        estado='Activo'
    )
    
    # Ejecución
    session.add(doctor)
    session.commit()
    
    # Verificación
    recuperado = session.query(Doctor).filter_by(id_doctor='DOC001').first()
    assert recuperado is not None
    assert recuperado.nombre_doctor == 'María Rodríguez'
    assert recuperado.especialidad == 'Cirugía Veterinaria'
    assert recuperado.numero_colegiado == 'COL-12345'
    assert recuperado.telefono == '+34 612345678'
    assert recuperado.correo == 'maria.rodriguez@clinicavet.com'
    assert recuperado.turno == 'Mañana'
    assert recuperado.estado == 'Activo'

