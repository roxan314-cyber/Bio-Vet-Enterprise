namespace Tests\Feature\Auth;

use App\Models\User;
use Illuminate\Foundation\Testing\RefreshDatabase;
use Illuminate\Foundation\Testing\WithFaker;
use Laravel\Sanctum\Sanctum;
use Tests\TestCase;

class AuthControllerTest extends TestCase
{
    use RefreshDatabase, WithFaker;

    private string $userPassword = 'password123';
    private array $userData;

    protected function setUp(): void
    {
        parent::setUp();
        
        $this->userData = [
            'name' => 'Juan Pérez',
            'email' => 'juan@test.com',
            'password' => $this->userPassword,
            'password_confirmation' => $this->userPassword,
            'rol' => 'veterinario',
            'telefono' => '123456789'
        ];
    }

    // ============================================
    // TESTS DE REGISTRO
    // ============================================

    /** @test */
    public function un_usuario_puede_registrarse_exitosamente()
    {
        $response = $this->postJson('/api/register', $this->userData);

        $response->assertStatus(201)
            ->assertJsonStructure([
                'success',
                'mensaje',
                'usuario' => ['id', 'name', 'email']
            ])
            ->assertJson([
                'success' => true,
                'mensaje' => 'Usuario registrado exitosamente',
                'usuario' => [
                    'name' => 'Juan Pérez',
                    'email' => 'juan@test.com'
                ]
            ]);

        $this->assertDatabaseHas('users', [
            'email' => 'juan@test.com',
            'name' => 'Juan Pérez',
            'rol' => 'veterinario'
        ]);
    }

    /** @test */
    public function registro_falla_con_email_duplicado()
    {
        // Crear usuario existente
        User::factory()->create(['email' => 'juan@test.com']);

        $response = $this->postJson('/api/register', $this->userData);

        $response->assertStatus(422)
            ->assertJsonValidationErrors(['email'])
            ->assertJsonFragment(['El email ya está registrado']);
    }

    /** @test */
    public function registro_falla_con_datos_invalidos()
    {
        $invalidData = [
            'name' => '',
            'email' => 'correo-invalido',
            'password' => '123',
            'password_confirmation' => '456'
        ];

        $response = $this->postJson('/api/register', $invalidData);

        $response->assertStatus(422)
            ->assertJsonValidationErrors(['name', 'email', 'password', 'password_confirmation']);
    }

    /** @test */
    public function registro_permite_rol_personalizado()
    {
        $this->userData['rol'] = 'admin';

        $response = $this->postJson('/api/register', $this->userData);

        $response->assertStatus(201);
        
        $this->assertDatabaseHas('users', [
            'email' => 'juan@test.com',
            'rol' => 'admin'
        ]);
    }

    // ============================================
    // TESTS DE LOGIN
    // ============================================

    /** @test */
    public function un_usuario_puede_login_exitosamente()
    {
        $user = User::factory()->create([
            'email' => 'juan@test.com',
            'password' => bcrypt($this->userPassword)
        ]);

        $response = $this->postJson('/api/login', [
            'email' => 'juan@test.com',
            'password' => $this->userPassword
        ]);

        $response->assertStatus(200)
            ->assertJsonStructure([
                'success',
                'mensaje',
                'token',
                'usuario' => ['id', 'name', 'email', 'rol']
            ])
            ->assertJson([
                'success' => true,
                'mensaje' => 'Login exitoso',
                'usuario' => [
                    'email' => 'juan@test.com'
                ]
            ]);

        // Verificar que se generó un token
        $this->assertNotNull($response->json('token'));
    }

    /** @test */
    public function login_falla_con_credenciales_incorrectas()
    {
        User::factory()->create([
            'email' => 'juan@test.com',
            'password' => bcrypt($this->userPassword)
        ]);

        $response = $this->postJson('/api/login', [
            'email' => 'juan@test.com',
            'password' => 'password_incorrecta'
        ]);

        $response->assertStatus(401)
            ->assertJson([
                'success' => false,
                'mensaje' => 'Credenciales inválidas'
            ]);
    }

    /** @test */
    public function login_falla_sin_email()
    {
        $response = $this->postJson('/api/login', [
            'password' => $this->userPassword
        ]);

        $response->assertStatus(422)
            ->assertJsonValidationErrors(['email']);
    }

    // ============================================
    // TESTS DE RUTAS PROTEGIDAS
    // ============================================

    /** @test */
    public function usuario_autenticado_puede_obtener_sus_datos()
    {
        $user = User::factory()->create();
        Sanctum::actingAs($user);

        $response = $this->getJson('/api/me');

        $response->assertStatus(200)
            ->assertJson([
                'success' => true,
                'usuario' => [
                    'id' => $user->id,
                    'name' => $user->name,
                    'email' => $user->email
                ]
            ]);
    }

    /** @test */
    public function usuario_no_autenticado_no_puede_obtener_sus_datos()
    {
        $response = $this->getJson('/api/me');

        $response->assertStatus(401);
    }

    /** @test */
    public function usuario_autenticado_puede_verificar_token()
    {
        $user = User::factory()->create();
        Sanctum::actingAs($user);

        $response = $this->postJson('/api/verify-token');

        $response->assertStatus(200)
            ->assertJson([
                'success' => true,
                'valid' => true,
                'mensaje' => 'Token válido',
                'usuario' => [
                    'id' => $user->id,
                    'email' => $user->email
                ]
            ])
            ->assertJsonStructure([
                'token' => ['expira_en', 'expira_en_horas', 'expira_en_fecha']
            ]);
    }

    /** @test */
    public function usuario_autenticado_puede_cerrar_sesion()
    {
        $user = User::factory()->create();
        Sanctum::actingAs($user);

        $response = $this->postJson('/api/logout');

        $response->assertStatus(200)
            ->assertJson([
                'success' => true,
                'mensaje' => 'Sesión cerrada exitosamente'
            ]);

        // Verificar que el token fue revocado
        $this->assertDatabaseCount('personal_access_tokens', 0);
    }

    /** @test */
    public function usuario_no_autenticado_no_puede_cerrar_sesion()
    {
        $response = $this->postJson('/api/logout');

        $response->assertStatus(401);
    }

    // ============================================
    // TESTS DE HEALTH CHECK
    // ============================================

    /** @test */
    public function health_check_retorna_estado_correcto()
    {
        $response = $this->getJson('/api/health');

        $response->assertStatus(200)
