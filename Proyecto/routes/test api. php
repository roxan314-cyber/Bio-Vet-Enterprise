    // ============================================
    // TESTS DE SEGURIDAD
    // ============================================

    /** @test */
    public function login_previene_ataques_de_fuerza_bruta()
    {
        $user = User::factory()->create(['email' => 'juan@test.com']);

        // 5 intentos fallidos
        for ($i = 0; $i < 5; $i++) {
