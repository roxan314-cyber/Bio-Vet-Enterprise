    // ============================================
    // TESTS DE VALIDACIONES AVANZADAS
    // ============================================

    /** @test */
    public function registro_requiere_password_de_al_menos_6_caracteres()
    {
        $this->userData['password'] = '12345';
        $this->userData['password_confirmation'] = '12345';

        $response = $this->postJson('/api/register', $this->userData);

        $response->assertStatus(422)
