<?php
namespace Core;

use PDO;
use Redis;

class Database {
    private static $instances = [];

    public static function getMySQL(): PDO {
        if (!isset(self::$instances['mysql'])) {
            $config = require __DIR__ . '/../config/database.php';
            $db = $config['mysql'];
            self::$instances['mysql'] = new PDO($db['dsn'], $db['user'], $db['pass']);
            self::$instances['mysql']->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
        }
        return self::$instances['mysql'];
    }

    public static function getRedis(): Redis {
        if (!isset(self::$instances['redis'])) {
            $config = require __DIR__ . '/../config/database.php';
            $redis = new Redis();
            $redis->connect($config['redis']['host'], $config['redis']['port']);
            self::$instances['redis'] = $redis;
        }
        return self::$instances['redis'];
    }
}

<?php
namespace Core;

class Router {
    private $routes = [];

    public function add($method, $path, $controller, $action) {
        $this->routes[] = compact('method', 'path', 'controller', 'action');
    }

    public function dispatch(Request $request): Response {
        $path = $request->getPath();
        $method = $request->getMethod();

        foreach ($this->routes as $route) {
            if ($route['method'] === $method && $route['path'] === $path) {
                $ctrl = new $route['controller']();
                return $ctrl->{$route['action']}($request);
            }
        }
        return new Response(404, ['error' => 'Not found']);
    }
}

<?php
namespace Controllers;

use Core\Request;
use Core\Response;
use Repositories\UserRepository;

class UserController {
    public function get(Request $req): Response {
        $id = $req->getParam('id');
        $data = UserRepository::find($id);
        return new Response(200, $data);
    }

    public function create(Request $req): Response {
        $body = $req->getBody();
        $id = UserRepository::create($body);
        return new Response(201, ['id' => $id]);
    }
}

