// backend/middlewares/security.js
const rateLimit = require('express-rate-limit');
const helmet = require('helmet');
const cors = require('cors');

// Rate Limiting - Evita ataques de fuerza bruta
const limiter = rateLimit({
    windowMs: 15 * 60 * 1000, // 15 minutos
    max: 100, // 100 peticiones por IP
    message: { error: 'Demasiadas peticiones, intenta más tarde' },
    standardHeaders: true,
    legacyHeaders: false,
});

// Aplicar a rutas sensibles
app.use('/api/login', limiter);
app.use('/api/register', limiter);
app.use('/api/contacto', limiter);

// Helmet - Protege contra vulnerabilidades web
app.use(helmet({
    contentSecurityPolicy: {
        directives: {
            defaultSrc: ["'self'"],
            scriptSrc: ["'self'", "https://unpkg.com"], // ScrollReveal
            styleSrc: ["'self'", "https://fonts.googleapis.com", "https://cdnjs.cloudflare.com"],
            fontSrc: ["'self'", "https://fonts.gstatic.com", "https://cdnjs.cloudflare.com"],
            imgSrc: ["'self'", "data:"],
        }
    }
}));

// CORS - Controla qué dominios pueden acceder
app.use(cors({
    origin: process.env.FRONTEND_URL || 'http://localhost:3000',
    credentials: true,
    optionsSuccessStatus: 200
}));

// Sanitización de entradas
const sanitize = require('express-validator');
app.use(sanitize());

// backend/routes/contacto.js
const { body, validationResult } = require('express-validator');

app.post('/api/contacto', [
    // Validación estricta de campos
    body('nombre')
        .trim()
        .isLength({ min: 2, max: 50 })
        .escape()
        .withMessage('Nombre inválido'),
    
    body('apellido')
        .trim()
        .isLength({ min: 2, max: 50 })
        .escape()
        .withMessage('Apellido inválido'),
    
    body('email')
        .trim()
        .isEmail()
        .normalizeEmail()
        .withMessage('Email inválido'),
    
    body('mensaje')
        .trim()
        .isLength({ min: 10, max: 1000 })
        .escape()
        .withMessage('Mensaje demasiado corto o largo'),
    
    // Protección contra spam (CAPTCHA)
    body('captcha')
        .optional()
        .isString()
], async (req, res) => {
    // Verificar errores de validación
    const errors = validationResult(req);
    if (!errors.isEmpty()) {
        return res.status(400).json({ 
            errors: errors.array() 
        });
    }

    try {
        // Verificar CAPTCHA (reCAPTCHA v3)
        const captchaResponse = req.body.captcha;
        if (captchaResponse) {
            const verification = await fetch(
                `https://www.google.com/recaptcha/api/siteverify`,
                {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `secret=${process.env.RECAPTCHA_SECRET}&response=${captchaResponse}`
                }
            );
            const data = await verification.json();
            if (!data.success || data.score < 0.5) {
                return res.status(403).json({ 
                    error: 'Verificación CAPTCHA fallida' 
                });
            }
        }

        // Guardar mensaje en BD
        await db.query(
            `INSERT INTO mensajes_contacto 
             (nombre, apellido, email, mensaje, ip, user_agent, fecha) 
             VALUES ($1, $2, $3, $4, $5, $6, NOW())`,
            [
                req.body.nombre,
                req.body.apellido,
                req.body.email,
                req.body.mensaje,
                req.ip,
                req.headers['user-agent']
            ]
        );

        // Enviar notificación al equipo (email, Slack, etc.)
        await enviarNotificacion(req.body);

        res.json({ 
            success: true, 
            mensaje: 'Mensaje enviado correctamente' 
        });

    } catch (error) {
        console.error('Error en contacto:', error);
        res.status(500).json({ 
            error: 'Error al enviar el mensaje' 
        });
    }
});

