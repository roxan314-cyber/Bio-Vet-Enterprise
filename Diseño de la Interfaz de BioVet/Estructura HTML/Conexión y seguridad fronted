// backend/routes/imagenes.js
const crypto = require('crypto');

// Generar URL firmada para imágenes
function generarUrlImagen(nombreArchivo, usuarioId) {
    const timestamp = Date.now();
    const firma = crypto
        .createHmac('sha256', process.env.IMAGEN_SECRET)
        .update(`${nombreArchivo}${timestamp}${usuarioId}`)
        .digest('hex')
        .substring(0, 16);
    
    return `/img/${firma}/${timestamp}/${nombreArchivo}`;
}

// Servir imagen con verificación
app.get('/img/:firma/:timestamp/:archivo', (req, res) => {
    const { firma, timestamp, archivo } = req.params;
    
    // Verificar firma
    const firmaEsperada = crypto
        .createHmac('sha256', process.env.IMAGEN_SECRET)
        .update(`${archivo}${timestamp}${req.usuario?.id || 'anonimo'}`)
        .digest('hex')
        .substring(0, 16);
    
    if (firma !== firmaEsperada) {
        return res.status(403).send('Acceso denegado');
    }
    
    // Verificar expiración (24 horas)
    if (Date.now() - parseInt(timestamp) > 86400000) {
        return res.status(410).send('URL expirada');
    }
    
    // Servir imagen (mapeo interno)
    const mapaImagenes = {
        'logo.jpg': 'public/imgweb/logo.jpg',
        'icono.jpg': 'public/imgweb/icono.jpg'
    };
    
    const rutaReal = mapaImagenes[archivo];
    if (!rutaReal) {
        return res.status(404).send('Imagen no encontrada');
    }
    
    res.sendFile(path.join(__dirname, '..', rutaReal));
});

