// backend/scripts/build.js (ejemplo con esbuild)
const esbuild = require('esbuild');

// Minificar CSS
const cssnano = require('cssnano');
const postcss = require('postcss');

// Construir assets con nombres hasheados
async function build() {
    // 1. Minificar JavaScript
    await esbuild.build({
        entryPoints: ['public/Codigo JS/script.js'],
        bundle: true,
        minify: true,
        outfile: 'dist/scripts/app.min.js',
        target: ['es2015']
    });
    
    // 2. Minificar CSS
    const css = fs.readFileSync('public/Estilos CSS/styleweb.css');
    const result = await postcss([cssnano]).process(css);
    fs.writeFileSync('dist/estilos/app.min.css', result.css);
    
    // 3. Generar mapa de archivos
    const manifest = {
        'scripts/app.js': 'dist/scripts/app.min.js',
        'estilos/app.css': 'dist/estilos/app.min.css'
    };
    fs.writeFileSync('dist/manifest.json', JSON.stringify(manifest));
}

