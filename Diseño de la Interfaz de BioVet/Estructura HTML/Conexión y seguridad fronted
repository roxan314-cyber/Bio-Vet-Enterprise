// backend/utils/hash.js
const crypto = require('crypto');
const fs = require('fs');

// Generar hash del contenido del archivo
function generarHash(archivo) {
    const contenido = fs.readFileSync(archivo);
    return crypto.createHash('md5').update(contenido).digest('hex').substring(0, 8);
}

// Ejemplo: /css/estilos?v=abc123def
app.get('/css/estilos', (req, res) => {
    const hash = generarHash(path.join(__dirname, 'public/Estilos CSS/styleweb.css'));
    res.setHeader('Cache-Control', 'public, max-age=31536000, immutable');
    res.sendFile(path.join(__dirname, 'public/Estilos CSS', 'styleweb.css'));
});

